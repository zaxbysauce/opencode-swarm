{
	"$schema": "https://biomejs.dev/schemas/2.3.14/schema.json",
	"files": {
		"includes": [
			"src/**",
			"tests/**",
			"test/**",
			"biome.json",
			"package.json",
			"tsconfig.json"
		]
	},
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noForEach": "off"
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always"
		}
	},
	"overrides": [
		{
			"includes": ["tests/**", "test/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off",
						"noUnusedFunctionParameters": "off",
						"noEmptyCharacterClassInRegex": "off",
						"noPrecisionLoss": "off"
					},
					"style": {
						"useTemplate": "off",
						"useNodejsImportProtocol": "off"
					},
					"complexity": {
						"useLiteralKeys": "off",
						"noBannedTypes": "off",
						"noUselessTernary": "off"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noTemplateCurlyInString": "off",
						"noTsIgnore": "off",
						"useIterableCallbackReturn": "off",
						"noImplicitAnyLet": "off",
						"noThenProperty": "off",
						"noAssignInExpressions": "off",
						"noSelfCompare": "off",
						"noApproximativeNumericConstant": "off"
					}
				}
			}
		}
	]
}
