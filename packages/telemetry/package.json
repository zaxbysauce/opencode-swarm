{
	"name": "@opencode-swarm/telemetry",
	"version": "8.0.0-beta.0",
	"description": "Telemetry event types and schemas for opencode-swarm",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"source": "./src/index.ts",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"license": "MIT",
	"scripts": {
		"build": "bun build src/index.ts --outdir dist --target bun --format esm && tsc --emitDeclarationOnly",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"zod": "^4.1.8"
	},
	"devDependencies": {
		"bun-types": "latest",
		"typescript": "^5.7.3"
	}
}
